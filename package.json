{
  "name": "antrosys-erp",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:clean": "pnpm --filter web clean && turbo build",
    "lint": "turbo lint",
    "db:migrate": "dotenv -e .env -- pnpm --filter api db:migrate",
    "db:seed": "dotenv -e .env -- pnpm --filter api db:seed",
    "db:reset": "dotenv -e .env -- pnpm --filter api db:reset"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.3.0"
  }
}

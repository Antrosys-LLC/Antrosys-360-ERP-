{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "lint": "tsc --noEmit",
    "db:migrate": "prisma migrate dev --name schema_update",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@antrosys/types": "workspace:*",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.1.0",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.0",
    "otplib": "^12.0.1",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.5",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "prisma": {

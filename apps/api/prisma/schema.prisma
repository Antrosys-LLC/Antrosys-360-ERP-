generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CEO
  CFO
  OPERATIONS_HEAD
  HR_HEAD
  FINANCE_MANAGER
  PROJECT_MANAGER
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  SUB_MANAGER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  REJECTED
}

enum ApprovalTaskStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum ApprovalTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalEntityType {
  PAYROLL
  VENDOR_EXPENSE
  INVOICE
}

enum FinancialActivityCategory {
  ACCOUNTS_PAYABLE
  PAYROLL
  INVOICE
  TAX
}

enum VendorPaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ClientPipelineStage {
  PROSPECT
  PROPOSAL
  NEGOTIATION
  ACTIVE
  AT_RISK
}

enum OperatingCostCategory {
  OPERATIONS
  SOFTWARE
  TAX_LEGAL
  BENEFITS
  OTHER
}

enum ServiceHealthStatus {
  OPERATIONAL
  DEGRADED
  DOWN
}

enum PipelineStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  }
enum Department {
  ENGINEERING
  OPERATIONS
  SALES
  FINANCE
  HR
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmploymentStatus {
  OFFER_SIGNED
  ONBOARDING
  ACTIVE
  OFFBOARDING
  TERMINATED
}

enum JobPostingStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER_SENT
  HIRED
  REJECTED
  WITHDRAWN
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum HrLetterType {
  OFFER
  APPOINTMENT
  EXPERIENCE
  SALARY_CERTIFICATE
  OTHER
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  WFH
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  passwordHash             String
  role                     Role
  mfaSecret                String?
  mfaEnabled               Boolean            @default(false)
  isActive                 Boolean            @default(true)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  employee                 Employee?
  auditLogs                AuditLog[]
  invoicesIssued           Invoice[]          @relation("InvoicesIssued")
  payrollsSubmitted        Payroll[]          @relation("PayrollSubmitted")
  payrollsApproved         Payroll[]          @relation("PayrollApproved")
  vendorPaymentsCreated    VendorPayment[]    @relation("VendorPaymentsCreated")
  approvalTasksAssigned    ApprovalTask[]     @relation("ApprovalTasksAssigned")
  financialEventsCreated   FinancialEvent[]   @relation("FinancialEventsCreated")
  notifications            Notification[]
  operatingExpensesCreated OperatingExpense[] @relation("OperatingExpensesCreated")
  jobRequisitionsCreated JobRequisition[] @relation("RequisitionCreatedBy")
  biReports             BIReport[]        @relation("UserBIReports")
  jobPostingsCreated       JobPosting[]       @relation("JobPostingsCreated")
  onboardingCreated        OnboardingRecord[] @relation("OnboardingCreated")
  hrLettersGenerated       HrLetter[]         @relation("HrLettersGenerated")

  @@map("users")
}

model Employee {
  id                     String           @id @default(cuid())
  userId                 String           @unique
  user                   User             @relation(fields: [userId], references: [id])
  employeeCode           String?          @unique
  firstName              String
  lastName               String
  preferredName          String?
  dateOfBirth            DateTime?
  gender                 Gender
  nationality            String?
  cnic                   String?
  phone                  String?
  personalEmail          String?
  personalPhone          String?
  emergencyContactName   String?
  emergencyContactRelation String?
  emergencyContactPhone  String?
  homeAddress            String?
  department             Department?
  designation            String?
  grade                  String?
  employeeType           String?
  location               String?
  employmentStatus       EmploymentStatus @default(ACTIVE)
  socialHandle           String?
  performanceScore       Int?
  kpiScore               Int?
  joiningDate            DateTime?
  terminatedAt           DateTime?
  contractType           String?
  probationEnd           DateTime?
  managerId              String?
  manager                Employee?        @relation("ManagerReports", fields: [managerId], references: [id])
  reports                Employee[]       @relation("ManagerReports")
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  approvalTasksRequested ApprovalTask[]
  attendances            Attendance[]
  leaveRequests          LeaveRequest[]   @relation("EmployeeLeaves")
  approvedLeaves         LeaveRequest[]   @relation("ApprovedLeaves")
  leaveBalances          LeaveBalance[]
  announcements          Announcement[]
  skills                 EmployeeSkill[]
  jobApplications        JobApplication[]
  onboarding             OnboardingRecord?
  hrLetters              HrLetter[]

  @@index([department])
  @@index([employmentStatus])
  @@index([isActive, employmentStatus])
  @@map("employees")
}

model EmployeeSkill {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skillName  String
  percentage Int? // If null, it's just a tag. If set, it's a progress bar.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@map("employee_skills")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  ipAddress  String?
  userAgent  String?
  statusCode Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Client {
  id             String              @id @default(cuid())
  name           String
  email          String?
  phone          String?
  pipelineStage  ClientPipelineStage @default(PROSPECT)
  monthlyRevenue Decimal?            @db.Decimal(14, 2)
  annualRevenue  Decimal?            @db.Decimal(14, 2)
  currencyCode   String              @default("USD") @db.VarChar(3)
  renewalDueAt   DateTime?
  isAtRisk       Boolean             @default(false)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  invoices       Invoice[]

  @@index([pipelineStage])
  @@index([isAtRisk])
  @@index([renewalDueAt])
  @@map("clients")
}

model Invoice {
  id                String            @id @default(cuid())
  invoiceNumber     String            @unique
  clientId          String
  client            Client            @relation(fields: [clientId], references: [id])
  status            InvoiceStatus     @default(DRAFT)
  invoiceDate       DateTime
  dueDate           DateTime
  paymentTermsDays  Int               @default(15)
  poNumber          String?
  currencyCode      String            @default("USD") @db.VarChar(3)
  taxRegion         String?
  notes             String?
  terms             String?
  stripePaymentLink String?
  subtotal          Decimal           @db.Decimal(14, 2)
  discountTotal     Decimal           @default(0) @db.Decimal(14, 2)
  taxableAmount     Decimal           @db.Decimal(14, 2)
  taxTotal          Decimal           @default(0) @db.Decimal(14, 2)
  withholdingTotal  Decimal           @default(0) @db.Decimal(14, 2)
  totalDue          Decimal           @db.Decimal(14, 2)
  issuedByUserId    String
  issuedBy          User              @relation("InvoicesIssued", fields: [issuedByUserId], references: [id])
  lineItems         InvoiceLineItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sortOrder     Int
  description   String
  quantity      Decimal  @db.Decimal(12, 4)
  unit          String?
  unitPrice     Decimal  @db.Decimal(14, 2)
  discountPct   Decimal  @default(0) @db.Decimal(5, 2)
  taxType       String
  taxRatePct    Decimal  @default(0) @db.Decimal(5, 2)
  lineSubtotal  Decimal  @db.Decimal(14, 2)
  lineTaxAmount Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal     Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payroll {
  id                String        @id @default(cuid())
  batchNumber       String        @unique
  periodStart       DateTime      @db.Date
  periodEnd         DateTime      @db.Date
  totalGross        Decimal       @db.Decimal(14, 2)
  totalNet          Decimal       @db.Decimal(14, 2)
  taxWithheld       Decimal       @default(0) @db.Decimal(14, 2)
  employeeCount     Int
  status            PayrollStatus @default(DRAFT)
  submittedByUserId String?
  submittedBy       User?         @relation("PayrollSubmitted", fields: [submittedByUserId], references: [id])
  approvedByUserId  String?
  approvedBy        User?         @relation("PayrollApproved", fields: [approvedByUserId], references: [id])
  approvedAt        DateTime?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("payrolls")
}

model DailyCashflow {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  inflowAmount  Decimal  @default(0) @db.Decimal(14, 2)
  outflowAmount Decimal  @default(0) @db.Decimal(14, 2)
  netAmount     Decimal  @default(0) @db.Decimal(14, 2)
  currencyCode  String   @default("USD") @db.VarChar(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@map("daily_cashflows")
}

model VendorPayment {
  id              String              @id @default(cuid())
  vendorName      String
  vendorReference String
  amount          Decimal             @db.Decimal(14, 2)
  currencyCode    String              @default("USD") @db.VarChar(3)
  status          VendorPaymentStatus @default(PAID)
  paidAt          DateTime
  createdByUserId String
  createdBy       User                @relation("VendorPaymentsCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([paidAt])
  @@index([status])
  @@map("vendor_payments")
}

model ApprovalTask {
  id                  String               @id @default(cuid())
  assigneeUserId      String
  assignee            User                 @relation("ApprovalTasksAssigned", fields: [assigneeUserId], references: [id])
  requesterEmployeeId String
  requester           Employee             @relation(fields: [requesterEmployeeId], references: [id])
  actionTitle         String
  priority            ApprovalTaskPriority @default(MEDIUM)
  status              ApprovalTaskStatus   @default(PENDING)
  entityType          ApprovalEntityType
  entityId            String
  dueAt               DateTime?
  resolvedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([assigneeUserId, status])
  @@index([entityType, entityId])
  @@map("approval_tasks")
}

model FinancialActivity {
  id         String                    @id @default(cuid())
  category   FinancialActivityCategory
  title      String
  occurredAt DateTime
  metadata   Json?
  createdAt  DateTime                  @default(now())

  @@index([occurredAt])
  @@index([category])
  @@map("financial_activities")
}

model FinancialEvent {
  id              String    @id @default(cuid())
  title           String
  subtitle        String?
  startAt         DateTime
  endAt           DateTime?
  unitLabel       String?
  isHighlighted   Boolean   @default(false)
  createdByUserId String?
  createdBy       User?     @relation("FinancialEventsCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([startAt])
  @@map("financial_events")
}

model OperatingExpense {
  id              String                @id @default(cuid())
  category        OperatingCostCategory
  amount          Decimal               @db.Decimal(14, 2)
  currencyCode    String                @default("USD") @db.VarChar(3)
  expenseDate     DateTime              @db.Date
  description     String?
  createdByUserId String
  createdBy       User                  @relation("OperatingExpensesCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([expenseDate])
  @@index([category])
  @@map("operating_expenses")
}

model CompanyMetricTarget {
  id           String   @id @default(cuid())
  metricKey    String
  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date
  targetValue  Decimal  @db.Decimal(14, 2)
  currencyCode String?  @default("USD") @db.VarChar(3)
  label        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([metricKey, periodStart])
  @@index([metricKey, periodStart, periodEnd])
  @@map("company_metric_targets")
}

model SystemServiceHealth {
  id            String              @id @default(cuid())
  serviceKey    String              @unique
  label         String
  status        ServiceHealthStatus @default(OPERATIONAL)
  lastCheckedAt DateTime            @default(now())
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("system_service_health")
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime  @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     String // "PRESENT", "ABSENT", "LATE", "LEAVE"
  hours      Decimal?  @db.Decimal(4, 2)
  isFlagged  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendances")
}

model LeaveRequest {
  id           String      @id @default(cuid())
  employeeId   String
  employee     Employee    @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  type         LeaveType
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  durationDays Int
  status       LeaveStatus @default(PENDING)
  reason       String?
  declineNote  String?
  approvedById String?
  approvedBy   Employee?   @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@map("leave_requests")
}

model LeaveBalance {
  id          String     @id @default(cuid())
  employeeId  String
  employee    Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year        Int
  type        LeaveType
  totalDays   Int        @default(0)
  takenDays   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([employeeId, year, type])
  @@index([employeeId, year])
  @@map("leave_balances")
}

model JobRequisition {
  id             String      @id @default(cuid())
  title          String
  department     String
  status         String      @default("ACTIVE") // ACTIVE, CLOSED, DRAFT
  
  createdByUserId String
  createdBy       User       @relation("RequisitionCreatedBy", fields: [createdByUserId], references: [id])
  
  candidates     Candidate[]
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("job_requisitions")
}

model Candidate {
  id                 String         @id @default(cuid())
  jobRequisitionId   String
  jobRequisition     JobRequisition @relation(fields: [jobRequisitionId], references: [id], onDelete: Cascade)
  
  name               String
  email              String?
  phone              String?
  role               String?
  experience         String?
  rating             Decimal?       @db.Decimal(3, 2)
  ratingType         String         @default("default")
  filesCount         Int            @default(0)
  
  tag                String?
  tagColor           String?
  
  pipelineStage      PipelineStage  @default(APPLIED)
  pipelineProgress   Int            @default(1)
  
  skills             String[]       @default([])
  
  interviewTitle     String?
  interviewLocation  String?
  interviewAt        DateTime?
  
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([pipelineStage])
  @@index([jobRequisitionId])
  @@map("candidates")
}
model JobPosting {
  id              String           @id @default(cuid())
  title           String
  department      Department
  description     String?
  location        String?
  status          JobPostingStatus @default(DRAFT)
  postedAt        DateTime?
  closedAt        DateTime?
  createdByUserId String
  createdBy       User             @relation("JobPostingsCreated", fields: [createdByUserId], references: [id])
  applications    JobApplication[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([department])
  @@map("job_postings")
}

model JobApplication {
  id              String           @id @default(cuid())
  jobPostingId    String
  jobPosting      JobPosting       @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  email           String
  phone           String?
  stage           ApplicationStage @default(APPLIED)
  appliedAt       DateTime         @default(now())
  stageChangedAt  DateTime         @default(now())
  interviewAt     DateTime?
  offerSentAt     DateTime?
  offerAcceptedAt DateTime?
  hiredAt         DateTime?
  rejectedAt      DateTime?
  employeeId      String?
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([jobPostingId])
  @@index([stage])
  @@index([appliedAt])
  @@map("job_applications")
}

model OnboardingRecord {
  id              String           @id @default(cuid())
  employeeId      String           @unique
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status          OnboardingStatus @default(NOT_STARTED)
  startDate       DateTime         @db.Date
  targetEndDate   DateTime?        @db.Date
  completedAt     DateTime?
  checklist       Json?
  createdByUserId String
  createdBy       User             @relation("OnboardingCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([startDate])
  @@map("onboarding_records")
}

model HrLetter {
  id                String       @id @default(cuid())
  type              HrLetterType
  employeeId        String
  employee          Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  subject           String
  body              String
  generatedByUserId String
  generatedBy       User         @relation("HrLettersGenerated", fields: [generatedByUserId], references: [id])
  createdAt         DateTime     @default(now())

  @@index([employeeId])
  @@map("hr_letters")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  authorId  String
  author    Employee @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
  @@map("announcements")
}

model Survey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("surveys")
}

model TeamMoodPulse {
  id         String   @id @default(cuid())
  department String
  date       DateTime @db.Date
  happy      Int      @default(0)
  neutral    Int      @default(0)
  stressed   Int      @default(0)
  unknown    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([department, date])
  @@map("team_mood_pulses")
}

model DepartmentKpi {
  id              String   @id @default(cuid())
  department      String   @unique
  sprintVelocity  Int      @default(84)
  bugResolution   Int      @default(72)
  codeReview      Int      @default(78)
  deliveryOnTime  Int      @default(91)
  teamUtilization Int      @default(82)
  openTickets     Int      @default(64)
  documentation   Int      @default(48)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("department_kpis")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

// =========================================================================
// BI & Reports Models
// =========================================================================

model BIReport {
  id           String        @id @default(cuid())
  title        String
  description  String?
  category     String        // e.g. "Finance", "HR", "Operations", "Sales"
  iconType     String        // e.g. "trend", "pipeline", "target", "turnover"
  isFavourite  Boolean       @default(false)
  isShared     Boolean       @default(false)
  config       Json?         // Custom builder config: { xAxis, yAxis, settings: { showDataLabels, showLegend, trendline }, filters, exportFormat }
  createdById  String
  createdBy    User          @relation("UserBIReports", fields: [createdById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  schedules    BISchedule[]
  executions   BIExecution[]

  @@map("bi_reports")
}

model BISchedule {
  id             String      @id @default(cuid())
  reportId       String
  report         BIReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title          String
  cronExpression String      // e.g. "0 8 * * 1"
  info           String      // Human readable schedule description, e.g. "Every Mon, 8:00 AM"
  deliveryMethod String      // e.g. "email" | "pdf"
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("bi_schedules")
}

model BIExecution {
  id         String    @id @default(cuid())
  reportId   String?
  report     BIReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  name       String    // Report Name
  duration   String    // e.g. "1.2s" or "-"
  status     String    // "COMPLETED" or "FAILED"
  failed     Boolean   @default(false)
  runAt      DateTime  @default(now())
  userId     String?
  createdAt  DateTime  @default(now())

  @@map("bi_executions")
}


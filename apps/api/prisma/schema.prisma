model DocumentFolder {
  id        String           @id @default(cuid())
  name      String
  parentId  String?
  parent    DocumentFolder?  @relation("FolderChildren", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderChildren")
  isLocked  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  documents Document[]

  @@index([parentId])
  @@map("document_folders")
}

model Document {
  id             String          @id @default(cuid())
  title          String
  fileName       String
  fileType       String
  fileSize       String
  fileUrl        String
  thumbnailUrl   String?
  isConfidential Boolean         @default(false)
  description    String?
  tags           String[]

  folderId       String
  folder         DocumentFolder  @relation(fields: [folderId], references: [id])

  employeeId     String?
  employee       Employee?       @relation("EmployeeDocuments", fields: [employeeId], references: [id])
  clientId       String?
  client         Client?         @relation("ClientDocuments", fields: [clientId], references: [id])

  uploadedById   String
  uploadedBy     User            @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([folderId])
  @@index([employeeId])
  @@index([clientId])
  @@index([title])
  @@map("documents")
}

// =========================================================================
// BI & Reports Models
// =========================================================================

model BIReport {
  id           String        @id @default(cuid())
  title        String
  description  String?
  category     String        // e.g. "Finance", "HR", "Operations", "Sales"
  iconType     String        // e.g. "trend", "pipeline", "target", "turnover"
  isFavourite  Boolean       @default(false)
  isShared     Boolean       @default(false)
  config       Json?         // Custom builder config: { xAxis, yAxis, settings: { showDataLabels, showLegend, trendline }, filters, exportFormat }
  createdById  String
  createdBy    User          @relation("UserBIReports", fields: [createdById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  schedules    BISchedule[]
  executions   BIExecution[]

  @@map("bi_reports")
}

model BISchedule {
  id             String      @id @default(cuid())
  reportId       String
  report         BIReport    @relation(fields: [reportId], references: [id], onDelete: Cascade)
  title          String
  cronExpression String      // e.g. "0 8 * * 1"
  info           String      // Human readable schedule description, e.g. "Every Mon, 8:00 AM"
  deliveryMethod String      // e.g. "email" | "pdf"
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@map("bi_schedules")
}

model BIExecution {
  id         String    @id @default(cuid())
  reportId   String?
  report     BIReport? @relation(fields: [reportId], references: [id], onDelete: SetNull)
  name       String    // Report Name
  duration   String    // e.g. "1.2s" or "-"
  status     String    // "COMPLETED" or "FAILED"
  failed     Boolean   @default(false)
  runAt      DateTime  @default(now())
  userId     String?
  createdAt  DateTime  @default(now())

  @@map("bi_executions")
}

// =========================================================================
// Ledger & Budget Module
// =========================================================================

model LedgerAccount {
  id           String        @id @default(cuid())
  code         String        @unique  // "1000", "2000", "4000", "6100", etc.
  name         String                 // "Assets", "Revenue", "Payroll", etc.
  description  String?
  sortOrder    Int           @default(0)
  /// Set only on expense/budget accounts — enables Budget vs Actual computation
  budgetAmount Decimal?      @db.Decimal(14, 2)
  currencyCode String        @default("PKR") @db.VarChar(3)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  entries      LedgerEntry[] @relation("AccountEntries")

  @@index([code])
  @@map("ledger_accounts")
}

model LedgerEntry {
  id              String          @id @default(cuid())
  date            DateTime        @db.Date
  ref             String          @db.VarChar(64)   // e.g. "INV-1042", "EXP-401"
  description     String
  entryType       LedgerEntryType
  amount          Decimal         @db.Decimal(14, 2)
  accountId       String
  account         LedgerAccount   @relation("AccountEntries", fields: [accountId], references: [id])
  isVoided        Boolean         @default(false)
  hasFlag         Boolean         @default(false)   // marks for reconciliation
  currencyCode    String          @default("PKR") @db.VarChar(3)
  voidedAt        DateTime?
  voidedByUserId  String?
  createdByUserId String
  createdBy       User            @relation("LedgerEntriesCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([date])
  @@index([accountId])
  @@index([isVoided])
  @@index([hasFlag])
  @@map("ledger_entries")
}

/// Stores the opening balance and balance-sheet snapshot for a named period.
/// Totals (credits, debits, closing balance) are derived at query-time from LedgerEntry.
model LedgerPeriodSummary {
  id                 String   @id @default(cuid())
  periodLabel        String   @unique  // e.g. "may-2026", "q2-2026"
  periodStart        DateTime @db.Date
  periodEnd          DateTime @db.Date
  openingBalance     Decimal  @db.Decimal(14, 2)
  currencyCode       String   @default("PKR") @db.VarChar(3)
  /// Accounting equation snapshot (balance sheet values)
  assetsTotal        Decimal  @default(0) @db.Decimal(14, 2)
  liabilitiesTotal   Decimal  @default(0) @db.Decimal(14, 2)
  equityTotal        Decimal  @default(0) @db.Decimal(14, 2)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([periodStart])
  @@map("ledger_period_summaries")
}


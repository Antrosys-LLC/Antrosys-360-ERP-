generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CEO
  CFO
  OPERATIONS_HEAD
  HR_HEAD
  FINANCE_MANAGER
  PROJECT_MANAGER
  MANAGER
  TEAM_LEAD
  EMPLOYEE
  SUB_MANAGER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PAID
  REJECTED
}

enum PayrollLifecycleStep {
  DATA_COLLECTION
  REVIEW_VERIFY
  PAYROLL_RUN
  CFO_APPROVAL
  DISBURSEMENT
}

enum PayrollLineStatus {
  PENDING
  PROCESSING
  ON_HOLD
  VERIFIED
}

enum ApprovalTaskStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum ApprovalTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ApprovalEntityType {
  PAYROLL
  VENDOR_EXPENSE
  INVOICE
}

enum FinancialActivityCategory {
  ACCOUNTS_PAYABLE
  PAYROLL
  INVOICE
  TAX
}

enum VendorPaymentStatus {
  PENDING
  PAID
  FAILED
}

enum ClientPipelineStage {
  PROSPECT
  PROPOSAL
  NEGOTIATION
  ACTIVE
  AT_RISK
}

enum ClientSalesStage {
  INITIAL_CONTACT
  PROPOSAL
  NEGOTIATION
  CONTRACT_REVIEW
  CLOSED_WON
}

enum OperatingCostCategory {
  OPERATIONS
  SOFTWARE
  TAX_LEGAL
  BENEFITS
  OTHER
}

enum ServiceHealthStatus {
  OPERATIONAL
  DEGRADED
  DOWN
}

enum PipelineStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  }
enum Department {
  ENGINEERING
  OPERATIONS
  SALES
  FINANCE
  HR
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmploymentStatus {
  OFFER_SIGNED
  ONBOARDING
  ACTIVE
  OFFBOARDING
  TERMINATED
}

enum JobPostingStatus {
  DRAFT
  OPEN
  CLOSED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW
  OFFER_SENT
  HIRED
  REJECTED
  WITHDRAWN
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum HrLetterType {
  OFFER
  APPOINTMENT
  EXPERIENCE
  SALARY_CERTIFICATE
  OTHER
}

enum PayslipStatus {
  PROCESSING
  PAID
  CANCELLED
}
enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
  HALF_DAY
}

enum LeaveType {
  ANNUAL
  SICK
  CASUAL
  MATERNITY
  OTHER
  WFH
  UNPAID
}

enum LeaveRequestStatus {
  PENDING
  PENDING_OPS_HEAD
  APPROVED
  REJECTED
  CANCELLED
}

enum LedgerEntryType {
  DEBIT
  CREDIT
}

model User {
  id                       String             @id @default(cuid())
  email                    String             @unique
  passwordHash             String
  role                     Role
  mfaSecret                String?
  mfaEnabled               Boolean            @default(false)
  isActive                 Boolean            @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  employee                 Employee?
  auditLogs                AuditLog[]
  invoicesIssued           Invoice[]          @relation("InvoicesIssued")
  payrollsSubmitted        Payroll[]          @relation("PayrollSubmitted")
  payrollsApproved         Payroll[]          @relation("PayrollApproved")
  vendorPaymentsCreated    VendorPayment[]    @relation("VendorPaymentsCreated")
  approvalTasksAssigned    ApprovalTask[]     @relation("ApprovalTasksAssigned")
  financialEventsCreated   FinancialEvent[]   @relation("FinancialEventsCreated")
  notifications            Notification[]
  operatingExpensesCreated OperatingExpense[] @relation("OperatingExpensesCreated")
  jobRequisitionsCreated JobRequisition[] @relation("RequisitionCreatedBy")
  biReports             BIReport[]        @relation("UserBIReports")
  jobPostingsCreated       JobPosting[]       @relation("JobPostingsCreated")
  onboardingCreated        OnboardingRecord[] @relation("OnboardingCreated")
  hrLettersGenerated       HrLetter[]         @relation("HrLettersGenerated")
  uploadedDocuments        Document[]         @relation("DocumentUploadedBy")
  assignedTasks            EmployeeTask[]     @relation("TaskAssignments")
  sentMessages             Message[]          @relation("SentMessages")
  workScheduleUpdates      WorkScheduleConfig[] @relation("WorkScheduleUpdatedBy")
  ledgerEntriesCreated     LedgerEntry[]      @relation("LedgerEntriesCreated")

  @@map("users")
}

model Employee {
  id                     String           @id @default(cuid())
  userId                 String           @unique
  user                   User             @relation(fields: [userId], references: [id])
  employeeCode           String?          @unique
  firstName              String
  lastName               String
  preferredName          String?
  dateOfBirth            DateTime?
  gender                 Gender
  nationality            String?
  cnic                   String?
  phone                  String?
  personalEmail          String?
  personalPhone          String?
  emergencyContactName   String?
  emergencyContactRelation String?
  emergencyContactPhone  String?
  homeAddress            String?
  department             Department?
  designation            String?
  grade                  String?
  employeeType           String?
  location               String?
  employmentStatus       EmploymentStatus @default(ACTIVE)
  socialHandle           String?
  performanceScore       Int?
  kpiScore               Int?
  joiningDate            DateTime?
  terminatedAt           DateTime?
  contractType           String?
  probationEnd           DateTime?
  managerId              String?
  manager                Employee?        @relation("ManagerReports", fields: [managerId], references: [id])
  reports                Employee[]       @relation("ManagerReports")
  isActive               Boolean          @default(true)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  approvalTasksRequested ApprovalTask[]
  attendances            Attendance[]
  leaveRequests          LeaveRequest[]   @relation("EmployeeLeaves")
  approvedLeaves         LeaveRequest[]   @relation("ApprovedLeaves")
  managerApprovedLeaves  LeaveRequest[]   @relation("ManagerApprovedLeaves")
  leaveBalances          LeaveBalance[]
  announcements          Announcement[]
  skills                 EmployeeSkill[]
  payslips               EmployeePayslip[]
  compensation           EmployeeCompensation?
  payrollLineItems       PayrollLineItem[]
  jobApplications        JobApplication[]
  onboarding             OnboardingRecord?
  hrLetters              HrLetter[]
  teamId                 String?
  team                   Team?            @relation("TeamMembers", fields: [teamId], references: [id])
  managedTeam            Team?            @relation("TeamManager")
  documents             Document[]           @relation("EmployeeDocuments")
  teams                 EmployeeTeam[]
  tasks                 EmployeeTask[]
  receivedMessages      Message[]            @relation("ReceivedMessages")

  @@index([department])
  @@index([employmentStatus])
  @@index([isActive, employmentStatus])
  @@map("employees")
}

model EmployeeSkill {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  skillName  String
  percentage Int? // If null, it's just a tag. If set, it's a progress bar.
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId])
  @@map("employee_skills")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  ipAddress  String?
  userAgent  String?
  statusCode Int?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Client {
  id             String              @id @default(cuid())
  clientCode     String?             @unique
  name           String
  email          String?
  phone          String?
  industry       String?
  tier           String?
  pipelineStage  ClientPipelineStage @default(PROSPECT)
  salesStage     ClientSalesStage?
  monthlyRevenue Decimal?            @db.Decimal(14, 2)
  annualRevenue  Decimal?            @db.Decimal(14, 2)
  lifetimeValue  Decimal?            @db.Decimal(14, 2)
  currencyCode   String              @default("PKR") @db.VarChar(3)
  healthScore    Int                 @default(75)
  healthMetrics  Json?
  renewalDueAt   DateTime?
  isAtRisk       Boolean             @default(false)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  invoices       Invoice[]
  documents      Document[]          @relation("ClientDocuments")
  statuses       ClientStatus[]
  renewals       ClientRenewal[]
  activities     ClientActivity[]
  projects       ClientProject[]
  tasks          ClientTask[]
  contacts       ClientContact[]
  timelineEvents ClientTimelineEvent[]

  @@index([pipelineStage])
  @@index([salesStage])
  @@index([isAtRisk])
  @@index([renewalDueAt])
  @@map("clients")
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@map("client_contacts")
}

model ClientStatus {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status    String   // ACTIVE, PROSPECT, PROPOSAL, NEGOTIATION, AT_RISK, INACTIVE
  note      String?
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([createdAt])
  @@map("client_statuses")
}

model ClientRenewal {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  dueAt       DateTime
  completedAt DateTime?
  amount      Decimal?  @db.Decimal(14, 2)
  status      String    @default("PENDING") // PENDING, COMPLETED, CANCELLED
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([dueAt])
  @@index([status])
  @@map("client_renewals")
}

model ClientActivity {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String   // NOTE, CALL, EMAIL, MEETING, TASK, PROJECT, STATUS_CHANGE, RENEWAL
  title       String
  description String?
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([createdAt])
  @@map("client_activities")
}

model ClientProject {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      String    @default("PLANNING") // PLANNING, ACTIVE, ON_HOLD, COMPLETED, CANCELLED
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?  @db.Decimal(14, 2)
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([status])
  @@map("client_projects")
}

model ClientTask {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueAt       DateTime?
  completedAt DateTime?
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([dueAt])
  @@index([status])
  @@map("client_tasks")
}

model ClientTimelineEvent {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  eventType   String   // CREATED, STATUS_CHANGED, RENEWAL_DUE, PROJECT_STARTED, PROJECT_COMPLETED, TASK_COMPLETED, ACTIVITY, NOTE_ADDED
  title       String
  description String?
  eventDate   DateTime @default(now())
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([eventDate])
  @@map("client_timeline_events")
}

model Invoice {
  id                String            @id @default(cuid())
  invoiceNumber     String            @unique
  clientId          String
  client            Client            @relation(fields: [clientId], references: [id])
  projectId         String?
  project           ClientProject?    @relation(fields: [projectId], references: [id])
  status            InvoiceStatus     @default(DRAFT)
  invoiceDate       DateTime
  dueDate           DateTime
  paymentTermsDays  Int               @default(15)
  poNumber          String?
  currencyCode      String            @default("USD") @db.VarChar(3)
  taxRegion         String?
  notes             String?
  terms             String?
  stripePaymentLink String?
  subtotal          Decimal           @db.Decimal(14, 2)
  discountTotal     Decimal           @default(0) @db.Decimal(14, 2)
  taxableAmount     Decimal           @db.Decimal(14, 2)
  taxTotal          Decimal           @default(0) @db.Decimal(14, 2)
  withholdingTotal  Decimal           @default(0) @db.Decimal(14, 2)
  totalDue          Decimal           @db.Decimal(14, 2)
  issuedByUserId    String
  issuedBy          User              @relation("InvoicesIssued", fields: [issuedByUserId], references: [id])
  lineItems         InvoiceLineItem[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([invoiceDate])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  sortOrder     Int
  description   String
  quantity      Decimal  @db.Decimal(12, 4)
  unit          String?
  unitPrice     Decimal  @db.Decimal(14, 2)
  discountPct   Decimal  @default(0) @db.Decimal(5, 2)
  taxType       String
  taxRatePct    Decimal  @default(0) @db.Decimal(5, 2)
  lineSubtotal  Decimal  @db.Decimal(14, 2)
  lineTaxAmount Decimal  @default(0) @db.Decimal(14, 2)
  lineTotal     Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payroll {
  id                  String               @id @default(cuid())
  batchNumber         String               @unique
  periodStart         DateTime             @db.Date
  periodEnd           DateTime             @db.Date
  totalGross          Decimal              @db.Decimal(14, 2)
  totalNet            Decimal              @db.Decimal(14, 2)
  totalDeductions     Decimal              @default(0) @db.Decimal(14, 2)
  taxWithheld         Decimal              @default(0) @db.Decimal(14, 2)
  employerLiability   Decimal              @default(0) @db.Decimal(14, 2)
  employeeCount       Int
  currencyCode        String               @default("PKR") @db.VarChar(3)
  lifecycleStep       PayrollLifecycleStep @default(DATA_COLLECTION)
  payslipConfig       Json?
  generationProgress  Int                  @default(0)
  status              PayrollStatus        @default(DRAFT)
  submittedByUserId   String?
  submittedBy         User?                @relation("PayrollSubmitted", fields: [submittedByUserId], references: [id])
  approvedByUserId    String?
  approvedBy          User?                @relation("PayrollApproved", fields: [approvedByUserId], references: [id])
  approvedAt          DateTime?
  paidAt              DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  lineItems           PayrollLineItem[]
  payslips            EmployeePayslip[]

  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("payrolls")
}

model EmployeeCompensation {
  id             String   @id @default(cuid())
  employeeId     String   @unique
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseSalary     Decimal  @db.Decimal(14, 2)
  allowances     Decimal  @default(0) @db.Decimal(14, 2)
  currencyCode   String   @default("PKR") @db.VarChar(3)
  effectiveFrom  DateTime @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("employee_compensations")
}

model PayrollLineItem {
  id              String            @id @default(cuid())
  payrollId       String
  payroll         Payroll           @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId      String
  employee        Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  baseSalary      Decimal           @db.Decimal(14, 2)
  allowances      Decimal           @default(0) @db.Decimal(14, 2)
  overtime        Decimal           @default(0) @db.Decimal(14, 2)
  bonuses         Decimal           @default(0) @db.Decimal(14, 2)
  grossPay        Decimal           @db.Decimal(14, 2)
  incomeTax       Decimal           @default(0) @db.Decimal(14, 2)
  providentFund   Decimal           @default(0) @db.Decimal(14, 2)
  healthInsurance Decimal           @default(0) @db.Decimal(14, 2)
  deductionsTotal Decimal           @db.Decimal(14, 2)
  taxAmount       Decimal           @default(0) @db.Decimal(14, 2)
  netPay          Decimal           @db.Decimal(14, 2)
  status          PayrollLineStatus @default(PENDING)
  holdReason      String?
  payslipId       String?           @unique
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([payrollId, employeeId])
  @@index([payrollId, status])
  @@map("payroll_line_items")
}

model DailyCashflow {
  id            String   @id @default(cuid())
  date          DateTime @unique @db.Date
  inflowAmount  Decimal  @default(0) @db.Decimal(14, 2)
  outflowAmount Decimal  @default(0) @db.Decimal(14, 2)
  netAmount     Decimal  @default(0) @db.Decimal(14, 2)
  currencyCode  String   @default("USD") @db.VarChar(3)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
  @@map("daily_cashflows")
}

model VendorPayment {
  id              String              @id @default(cuid())
  vendorName      String
  vendorReference String
  amount          Decimal             @db.Decimal(14, 2)
  currencyCode    String              @default("USD") @db.VarChar(3)
  status          VendorPaymentStatus @default(PAID)
  paidAt          DateTime
  createdByUserId String
  createdBy       User                @relation("VendorPaymentsCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([paidAt])
  @@index([status])
  @@map("vendor_payments")
}

model ApprovalTask {
  id                  String               @id @default(cuid())
  assigneeUserId      String
  assignee            User                 @relation("ApprovalTasksAssigned", fields: [assigneeUserId], references: [id])
  requesterEmployeeId String
  requester           Employee             @relation(fields: [requesterEmployeeId], references: [id])
  actionTitle         String
  priority            ApprovalTaskPriority @default(MEDIUM)
  status              ApprovalTaskStatus   @default(PENDING)
  entityType          ApprovalEntityType
  entityId            String
  dueAt               DateTime?
  resolvedAt          DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([assigneeUserId, status])
  @@index([entityType, entityId])
  @@map("approval_tasks")
}

model FinancialActivity {
  id         String                    @id @default(cuid())
  category   FinancialActivityCategory
  title      String
  occurredAt DateTime
  metadata   Json?
  createdAt  DateTime                  @default(now())

  @@index([occurredAt])
  @@index([category])
  @@map("financial_activities")
}

model FinancialEvent {
  id              String    @id @default(cuid())
  title           String
  subtitle        String?
  startAt         DateTime
  endAt           DateTime?
  unitLabel       String?
  isHighlighted   Boolean   @default(false)
  createdByUserId String?
  createdBy       User?     @relation("FinancialEventsCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([startAt])
  @@map("financial_events")
}

model OperatingExpense {
  id              String                @id @default(cuid())
  category        OperatingCostCategory
  amount          Decimal               @db.Decimal(14, 2)
  currencyCode    String                @default("USD") @db.VarChar(3)
  expenseDate     DateTime              @db.Date
  description     String?
  createdByUserId String
  createdBy       User                  @relation("OperatingExpensesCreated", fields: [createdByUserId], references: [id])
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([expenseDate])
  @@index([category])
  @@map("operating_expenses")
}

model CompanyMetricTarget {
  id           String   @id @default(cuid())
  metricKey    String
  periodStart  DateTime @db.Date
  periodEnd    DateTime @db.Date
  targetValue  Decimal  @db.Decimal(14, 2)
  currencyCode String?  @default("USD") @db.VarChar(3)
  label        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([metricKey, periodStart])
  @@index([metricKey, periodStart, periodEnd])
  @@map("company_metric_targets")
}

model SystemServiceHealth {
  id            String              @id @default(cuid())
  serviceKey    String              @unique
  label         String
  status        ServiceHealthStatus @default(OPERATIONAL)
  lastCheckedAt DateTime            @default(now())
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@map("system_service_health")
}

model Attendance {
  id              String           @id @default(cuid())
  employeeId      String
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date            DateTime         @db.Date
  checkIn         DateTime?
  checkOut        DateTime?
  checkInLocation String?
  status          AttendanceStatus @default(ABSENT)
  hours           Decimal?         @db.Decimal(4, 2)
  overtimeHours   Decimal?         @db.Decimal(4, 2)
  isFlagged       Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("attendances")
}

model LeaveRequest {
  id                      String             @id @default(cuid())
  employeeId              String
  employee                Employee           @relation("EmployeeLeaves", fields: [employeeId], references: [id], onDelete: Cascade)
  type                    LeaveType
  startDate               DateTime           @db.Date
  endDate                 DateTime           @db.Date
  durationDays            Int
  status                  LeaveRequestStatus @default(PENDING)
  reason                  String?
  attachmentUrl           String?
  declineNote             String?
  requiresOpsHeadApproval Boolean            @default(false)
  managerApprovedById     String?
  managerApprovedBy       Employee?          @relation("ManagerApprovedLeaves", fields: [managerApprovedById], references: [id])
  managerApprovedAt       DateTime?
  approvedById            String?
  approvedBy              Employee?          @relation("ApprovedLeaves", fields: [approvedById], references: [id])
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([startDate])
  @@index([requiresOpsHeadApproval])
  @@map("leave_requests")
}

model LeaveBalance {
  id            String    @id @default(cuid())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType     LeaveType
  year          Int
  allocatedDays Decimal   @db.Decimal(5, 1)
  usedDays      Decimal   @default(0) @db.Decimal(5, 1)
  pendingDays   Decimal   @default(0) @db.Decimal(5, 1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([employeeId, leaveType, year])
  @@index([employeeId, year])
  @@map("leave_balances")
}

model EmployeePayslip {
  id              String        @id @default(cuid())
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollId       String?
  payroll         Payroll?      @relation(fields: [payrollId], references: [id], onDelete: SetNull)
  periodStart     DateTime      @db.Date
  periodEnd       DateTime      @db.Date
  periodLabel     String
  currencyCode    String        @default("PKR") @db.VarChar(3)
  grossPay        Decimal       @db.Decimal(14, 2)
  netPay          Decimal       @db.Decimal(14, 2)
  taxAmount       Decimal       @default(0) @db.Decimal(14, 2)
  deductionsTotal Decimal       @default(0) @db.Decimal(14, 2)
  netPayRatioPct  Int           @default(78)
  status          PayslipStatus @default(PROCESSING)
  documentUrl     String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([employeeId, periodStart])
  @@index([employeeId, periodStart])
  @@map("employee_payslips")
}

model CompanyHoliday {
